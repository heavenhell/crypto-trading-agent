# ============================================================
# 复制本文件为 .env，填入你的真实密钥。.env 不要提交到 git。
# ============================================================

# --- Binance 现货 Testnet（在 https://testnet.binance.vision 申请）---
BINANCE_SPOT_TESTNET_API_KEY=your_spot_testnet_key
BINANCE_SPOT_TESTNET_SECRET=your_spot_testnet_secret

# --- Binance 合约 Testnet（在 https://testnet.binancefuture.com 申请，和现货是【不同】的一套 key）---
BINANCE_FUTURES_TESTNET_API_KEY=your_futures_testnet_key
BINANCE_FUTURES_TESTNET_SECRET=your_futures_testnet_secret

# --- LLM ---
# 用 OpenAI：
OPENAI_API_KEY=your_openai_key
# 用 DeepSeek（OpenAI 兼容，二选一，见 config/settings.py 的 LLM_PROVIDER）：
DEEPSEEK_API_KEY=your_deepseek_key

# --- 运行模式：testnet（默认，强烈建议）/ mainnet（最后阶段才用）---
TRADING_MODE=testnet
